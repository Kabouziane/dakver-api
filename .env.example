SECRET_KEY=change-me-in-production-use-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,api.toitureverte.be

# PostgreSQL
DB_NAME=toitureverte
DB_USER=toitureverte
DB_PASSWORD=change-me
DB_HOST=localhost
DB_PORT=5432

# CORS – origins autorisées (Nuxt frontend)
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://www.toitureverte.be

# Google OAuth (Google Cloud Console → Credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Apple OAuth (Apple Developer → Sign In with Apple)
APPLE_CLIENT_ID=
APPLE_SECRET=

# Email (pour les notifications)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=ToitureVerte <noreply@toitureverte.be>

# Media files
MEDIA_ROOT=/var/www/toitureverte/media

# Frontend URL (pour les redirects OAuth)
FRONTEND_URL=https://www.toitureverte.be
